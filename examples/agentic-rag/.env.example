# Required: OpenAI API key for the search skill (GPT-4o)
OPENAI_API_KEY=sk-...

# Optional: override the default model (default: gpt-4o)
# OPENAI_MODEL=gpt-4o-mini

# Optional: path to persist ChromaDB collections (default: ./chroma_data)
# CHROMA_PATH=./chroma_data

# Optional: admin key for /admin-mcp access (default: dev-secret)
# ADMIN_KEY=dev-secret
